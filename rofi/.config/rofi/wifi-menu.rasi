@import "~/.config/rofi/config.rasi"

window {
    width: 760px;
}

mainbox {
    padding: 22px;
}

inputbar {
    border: 1px solid;
    border-color: @aqua;
}

textbox-prompt-colon {
    enabled: false;
    str: "";
}

entry {
    padding: 0px;
    placeholder: "select network...";
}

listview {
    lines: 12;
    fixed-height: false;
}

element {
    padding: 8px 10px;
}

element-text {
    horizontal-align: 0.0;
}
