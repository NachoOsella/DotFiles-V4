[Unit]
Description=Clean Arch (deep cleanup)
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
# Legacy reference unit. Prefer systemd-user/.config/systemd/user/clean-arch.service.
ExecStart=/usr/bin/fish %h/dotfiles/scripts/clean_arch.fish --yes --no-spinner --config=%h/dotfiles/scripts/clean_arch.conf --report-json=/tmp/clean-arch/last-run.json
Nice=10
IOSchedulingClass=idle
