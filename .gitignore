# OS files
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo
*~

# Nvim
nvim/.config/nvim/lazy-lock.json
nvim/.config/nvim/.luarc.json

# Fish
fish/.config/fish/fish_variables

# Yazi plugins (reinstall with ya pack)
yazi/.config/yazi/plugins/

# Pi task state
**/.pi/tasks/

# KeePassXC databases
keepassxc/.config/keepassxc/*.kdbx

# Pcmanfm-qt (runtime data)
pcmanfm-qt/.config/pcmanfm-qt/default/recent-files.conf

# Pi agent
pi/.pi/agent/sessions/
pi/.pi/agent/git/
pi/.pi/agent/auth.json
pi/.pi/agent/pi-crash.log

# Sensitive files
*.pem
*.key
*credentials*
*secret*

# KeePassXC local config can contain KeeShare private keys
keepassxc/.config/keepassxc/keepassxc.ini
